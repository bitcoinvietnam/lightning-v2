<section class="hero" id="hero">
  <div class="container">
    <div class="hero-content">
      <div class="reveal reveal-up">
        <div class="hero-badge">
          <div class="pulse"></div>
          {{ site.hero.badge }}
        </div>
        <h1>
          {{ site.hero.headlinePart1 }}<br />
          {{ site.hero.headlinePart2 }} <span class="gradient-text">{{ site.hero.headlineAccent }}</span>
        </h1>
        <p>{{ site.hero.description }}</p>
        <div class="hero-actions">
          <a href="{{ site.hero.primaryCta.href }}" class="btn btn-primary">{{ site.hero.primaryCta.label }}</a>
          <a href="{{ site.hero.secondaryCta.href }}" class="btn btn-outline">{{ site.hero.secondaryCta.label }}</a>
        </div>
      </div>
      <div class="hero-visual reveal reveal-scale">
        <canvas id="networkCanvas" class="network-canvas"></canvas>
        <div class="hero-orb">
          <div class="orb-ring"></div>
          <div class="orb-ring"></div>
          <div class="orb-ring"></div>
          <div class="orb-ring"></div>
          <div class="orb-center">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2" fill="currentColor" stroke="none"/>
            </svg>
          </div>
          <div class="orb-node"></div>
          <div class="orb-node"></div>
          <div class="orb-node"></div>
          <div class="orb-node"></div>
          <div class="orb-node"></div>
        </div>
      </div>
    </div>
  </div>
</section>
