<section class="node-section section" id="node">
  <div class="container">
    <div class="section-header reveal">
      <div class="section-tag">{{ site.nodeSection.tag }}</div>
      <h2>{{ site.nodeSection.title }} <span class="gradient-text">{{ site.nodeSection.titleAccent }}</span></h2>
      <p>{{ site.nodeSection.description }}</p>
    </div>
    <div class="node-tabs-wrap reveal">
      <div class="node-tabs">
        {% for node in site.nodes %}
        <button class="node-tab{% if loop.first %} active{% endif %}" data-tab="{{ loop.index0 }}" onclick="switchNodeTab({{ loop.index0 }})">
          <div class="node-tab-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
            </svg>
          </div>
          <div class="node-tab-info">
            <span class="node-tab-name">{{ node.name }}</span>
            <span class="node-selling-point node-selling-point--{{ node.type | lower }}">{{ node.typeDescription }}</span>
          </div>
          <div class="node-tab-status">
            <div class="dot"></div>
            {{ node.status }}
          </div>
        </button>
        {% endfor %}
      </div>
      <div class="node-card">
        {% for node in site.nodes %}
        <div class="node-panel{% if loop.first %} active{% endif %}" data-panel="{{ loop.index0 }}">
          <div class="node-body">
            <div class="node-panel-header">
              <h3>{{ node.name }} <span class="node-type-label node-type-label--{{ node.type | lower }}">{{ node.type }}</span></h3>
              {% set ranks = nodeRanks[node.pubkey] %}
              {% if ranks %}
              <div class="node-ranks" data-pubkey="{{ node.pubkey }}">
                <div class="node-rank">
                  <span class="node-rank-label">Channels Rank</span>
                  <span class="node-rank-value" data-rank-to="{{ ranks.channels }}">#{{ ranks.channels | localeString }}</span>
                  {% if ranks.channelsChange > 0 %}
                  <span class="node-rank-change">
                    <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor"><path d="M12 4l-8 8h5v8h6v-8h5z"/></svg>
                    {{ ranks.channelsChange | localeString }}
                  </span>
                  {% endif %}
                </div>
                <div class="node-rank">
                  <span class="node-rank-label">Capacity Rank</span>
                  <span class="node-rank-value" data-rank-to="{{ ranks.capacity }}">#{{ ranks.capacity | localeString }}</span>
                  {% if ranks.capacityChange > 0 %}
                  <span class="node-rank-change">
                    <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor"><path d="M12 4l-8 8h5v8h6v-8h5z"/></svg>
                    {{ ranks.capacityChange | localeString }}
                  </span>
                  {% endif %}
                </div>
              </div>
              {% endif %}
            </div>
            <div class="pubkey-section">
              <div class="pubkey-label">Public Key</div>
              <div class="pubkey-value" title="Click to copy" onclick="copyPubkey(this)">
                <span>{{ node.pubkey }}</span>
                <button class="copy-btn" aria-label="Copy">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
                  </svg>
                </button>
              </div>
            </div>
            <div class="node-info-grid">
              {% for info in node.info %}
                <div class="node-info-item">
                  <div class="label">{{ info.label }}</div>
                  <div class="value{% if info.color === 'accent' %} text-accent{% elif info.color === 'green' %} text-green{% endif %}">{{ info.value }}</div>
                </div>
              {% endfor %}
            </div>
            <div class="node-links">
              {% if node.mempoolUrl %}
              <a href="{{ node.mempoolUrl }}" target="_blank" rel="noopener" class="node-ext-link">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                  <polyline points="15 3 21 3 21 9"/>
                  <line x1="10" y1="14" x2="21" y2="3"/>
                </svg>
                mempool.space
              </a>
              {% endif %}
              {% if node.ambossUrl %}
              <a href="{{ node.ambossUrl }}" target="_blank" rel="noopener" class="node-ext-link">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                  <polyline points="15 3 21 3 21 9"/>
                  <line x1="10" y1="14" x2="21" y2="3"/>
                </svg>
                amboss.space
              </a>
              {% endif %}
            </div>
          </div>
        </div>
        {% endfor %}
      </div>
    </div>
    <div class="node-footer-section reveal">
      <p>{{ site.nodeSection.footerText | safe }}</p>
      <a href="{{ site.nodeSection.footerCta.href }}" class="btn btn-primary" target="_blank" rel="noopener">{{ site.nodeSection.footerCta.label }}</a>
    </div>
  </div>
</section>
